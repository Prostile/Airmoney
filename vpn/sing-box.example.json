{
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "local_dns",
        "type": "udp",
        "server": "77.88.8.8"
      },
      {
        "tag": "remote_dns",
        "type": "udp",
        "server": "8.8.8.8",
        "domain_resolver": "local_dns",
        "detour": "proxy"
      }
    ],
    "rules": [
      {
        "server": "local_dns",
        "domain": [
          "sub.example.com"
        ]
      }
    ],
    "final": "remote_dns"
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "socks",
      "listen": "0.0.0.0",
      "listen_port": 10808
    },
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "singbox_tun",
      "address": [
        "172.31.255.1/30"
      ],
      "mtu": 9000,
      "auto_route": true,
      "strict_route": true,
      "stack": "gvisor"
    }
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "proxy",
      "server": "sub.example.com",
      "server_port": 443,
      "uuid": "00000000-0000-0000-0000-000000000000",
      "flow": "xtls-rprx-vision",
      "packet_encoding": "xudp",
      "tls": {
        "enabled": true,
        "server_name": "sub.example.com",
        "insecure": false,
        "alpn": [
          "http/1.1"
        ],
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        }
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "default_domain_resolver": {
      "server": "local_dns"
    },
    "auto_detect_interface": true,
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": [
          "dns"
        ],
        "action": "hijack-dns"
      },
      {
        "outbound": "direct",
        "domain": [
          "sub.example.com"
        ]
      },
      {
        "outbound": "direct",
        "ip_is_private": true
      },
      {
        "network": [
          "udp"
        ],
        "port": [
          443
        ],
        "action": "reject"
      },
      {
        "outbound": "proxy",
        "port_range": [
          "0:65535"
        ]
      }
    ],
    "final": "proxy"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "/var/lib/sing-box/cache.db",
      "store_fakeip": false
    }
  }
}
